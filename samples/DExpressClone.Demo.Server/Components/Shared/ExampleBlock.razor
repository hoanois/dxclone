@inject IJSRuntime JS

<div class="example-block">
    <h3>@Title</h3>
    @if (Description is not null)
    {
        <p class="example-description">@Description</p>
    }
    <div class="live-demo">
        <div class="live-demo-label">Live Demo</div>
        @Demo
    </div>
    <div class="code-block">
        <div class="code-block-header">
            <span class="code-block-lang">@Language</span>
            <button class="copy-btn @(_copied ? "copy-btn--copied" : "")" @onclick="CopyCode">
                @(_copied ? "Copied!" : "Copy")
            </button>
        </div>
        <pre><code id="@_elementId">@Code</code></pre>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = "";
    [Parameter] public string? Description { get; set; }
    [Parameter, EditorRequired] public RenderFragment Demo { get; set; } = default!;
    [Parameter] public RenderFragment? Code { get; set; }
    [Parameter] public string Language { get; set; } = "razor";

    private bool _copied;
    private string _elementId = "code-" + Guid.NewGuid().ToString("N")[..8];

    private async Task CopyCode()
    {
        await JS.InvokeVoidAsync("eval",
            "navigator.clipboard.writeText(document.getElementById('" + _elementId + "').innerText)");
        _copied = true;
        StateHasChanged();
        await Task.Delay(2000);
        _copied = false;
        StateHasChanged();
    }
}
