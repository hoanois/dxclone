@page "/"

<PageTitle>DExpressClone Demo</PageTitle>

<div class="demo-home">
    <h1>Welcome to DExpressClone</h1>
    <p class="demo-subtitle">A comprehensive Blazor component library inspired by DevExpress</p>

    <div class="demo-card-grid">
        <a href="grid" class="demo-card">
            <div class="demo-card-icon">&#9638;</div>
            <h3>Data Grid</h3>
            <p>High-performance data grid with sorting, filtering, selection, and virtual scrolling.</p>
        </a>
        <a href="editors" class="demo-card">
            <div class="demo-card-icon">&#9998;</div>
            <h3>Editors</h3>
            <p>TextBox, NumericEdit, CheckBox, RadioGroup, DateEdit, ComboBox and more.</p>
        </a>
        <a href="charts" class="demo-card">
            <div class="demo-card-icon">&#9670;</div>
            <h3>Charts</h3>
            <p>Line, Bar, and Pie charts with SVG rendering, legends, and tooltips.</p>
        </a>
        <a href="layout" class="demo-card">
            <div class="demo-card-icon">&#9776;</div>
            <h3>Layout</h3>
            <p>Buttons, Panels, Tabs, Accordion, and Toolbar components.</p>
        </a>
    </div>

    <div class="demo-features">
        <h2>Features</h2>
        <ul>
            <li>Fluent Design theme with CSS custom properties</li>
            <li>Dark and Light theme support</li>
            <li>Full Blazor Server and WebAssembly support</li>
            <li>Keyboard navigation and accessibility</li>
            <li>EditForm integration with validation</li>
        </ul>
    </div>
</div>
