                <tr><td><code>AllowFilter</code></td><td><code>bool</code></td><td><code>false</code></td><td>Whether column filtering is enabled.</td></tr>
                <tr><td><code>SelectedItem</code></td><td><code>TItem?</code></td><td><code>null</code></td><td>The currently selected row item.</td></tr>
                <tr><td><code>SelectedItemChanged</code></td><td><code>EventCallback&lt;TItem&gt;</code></td><td>—</td><td>Fires when the selected row changes.</td></tr>
                <tr><td><code>ChildContent</code></td><td><code>RenderFragment</code></td><td>—</td><td>DxGridDataColumn children.</td></tr>
            </tbody>
        </table>

        <h3>DxGridDataColumn Parameters</h3>
        <table class="params-table">
            <thead><tr><th>Name</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
            <tbody>
                <tr><td><code>FieldName</code></td><td><code>string</code></td><td>—</td><td>Property name to bind the column to.</td></tr>
                <tr><td><code>Caption</code></td><td><code>string?</code></td><td><code>null</code></td><td>Column header text (defaults to FieldName).</td></tr>
                <tr><td><code>Width</code></td><td><code>string?</code></td><td><code>null</code></td><td>Column width (e.g. "150px", "20%").</td></tr>
                <tr><td><code>Format</code></td><td><code>string?</code></td><td><code>null</code></td><td>Display format string for the column values.</td></tr>
                <tr><td><code>AllowSort</code></td><td><code>bool</code></td><td><code>true</code></td><td>Whether this column is sortable.</td></tr>
            </tbody>
        </table>

        <h3>Server-Side Data Loading (CustomData)</h3>
        <table class="params-table">
            <thead><tr><th>Name</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
            <tbody>
                <tr><td><code>CustomData</code></td><td><code>Func&lt;GridDataLoadOptions, CancellationToken, Task&lt;GridDataLoadResult&lt;TItem&gt;&gt;&gt;?</code></td><td><code>null</code></td><td>Server-side data callback. When set, sorting, filtering, and paging are handled by the callback.</td></tr>
            </tbody>
        </table>

        <h4>GridDataLoadOptions</h4>
        <table class="params-table">
