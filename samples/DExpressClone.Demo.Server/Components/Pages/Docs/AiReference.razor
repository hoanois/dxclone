        <table class="params-table">
            <thead><tr><th>Rule</th><th>Key Property</th><th>Description</th></tr></thead>
            <tbody>
                <tr><td><code>RequiredRule</code></td><td>—</td><td>Value must not be null or empty.</td></tr>
                <tr><td><code>EmailRule</code></td><td>—</td><td>Value must be a valid email address.</td></tr>
                <tr><td><code>RegexRule</code></td><td><code>Pattern</code></td><td>Value must match the regex pattern.</td></tr>
                <tr><td><code>MatchRule</code></td><td><code>MatchValue</code> (Func)</td><td>Value must equal the result of MatchValue.</td></tr>
                <tr><td><code>MinLengthRule</code></td><td><code>Length</code></td><td>String length must be at least Length.</td></tr>
                <tr><td><code>MaxLengthRule</code></td><td><code>Length</code></td><td>String length must be at most Length.</td></tr>
                <tr><td><code>RangeRule</code></td><td><code>Min</code>, <code>Max</code></td><td>Numeric value must be within the range.</td></tr>
                <tr><td><code>CustomRule</code></td><td><code>ValidateFunc</code></td><td>Custom validation function returning bool.</td></tr>
            </tbody>
        </table>

        <h3>Example</h3>
