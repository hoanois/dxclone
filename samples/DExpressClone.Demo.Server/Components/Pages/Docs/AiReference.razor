    &lt;/DxFormItem&gt;
    &lt;DxFormItem FieldName="Email" LabelText="Email" Required Email&gt;
        &lt;DxTextBox @@bind-Value="model.Email" /&gt;
    &lt;/DxFormItem&gt;
    &lt;DxFormItem FieldName="Age" LabelText="Age"&gt;
