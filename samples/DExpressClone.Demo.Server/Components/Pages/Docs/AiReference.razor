                <tr><td><code>--dx-color-danger</code></td><td>Danger/error state color (red).</td></tr>
                <tr><td><code>--dx-color-info</code></td><td>Info state color (blue).</td></tr>
            </tbody>
        </table>

        <h3>Spacing, Radius, and Shadows</h3>
        <table class="params-table">
            <thead><tr><th>Variable</th><th>Description</th></tr></thead>
            <tbody>
                <tr><td><code>--dx-radius-sm</code></td><td>Small border radius.</td></tr>
                <tr><td><code>--dx-radius-md</code></td><td>Medium border radius.</td></tr>
                <tr><td><code>--dx-radius-lg</code></td><td>Large border radius.</td></tr>
                <tr><td><code>--dx-spacing-1</code> through <code>--dx-spacing-8</code></td><td>Spacing scale (1 = smallest, 8 = largest).</td></tr>
                <tr><td><code>--dx-shadow-sm</code></td><td>Small box shadow.</td></tr>
                <tr><td><code>--dx-shadow-md</code></td><td>Medium box shadow.</td></tr>
                <tr><td><code>--dx-shadow-lg</code></td><td>Large box shadow.</td></tr>
                <tr><td><code>--dx-shadow-xl</code></td><td>Extra-large box shadow.</td></tr>
            </tbody>
        </table>

        <h3>Dark Mode</h3>
        <pre><code>&lt;html data-dx-theme="dark"&gt;</code></pre>
        <p>Add the <code>data-dx-theme="dark"</code> attribute to the <code>&lt;html&gt;</code> element to enable dark mode. All CSS variables automatically adjust.</p>
    </section>

    <!-- ===== SECTION 5: COMMON PATTERNS ===== -->
    <section class="doc-section">
        <h2>Common Patterns</h2>

        <h3>Two-Way Binding</h3>
        <pre><code>&lt;DxTextBox @@bind-Value="model.Name" /&gt;
&lt;DxNumericEdit @@bind-Value="model.Price" /&gt;
&lt;DxCheckBox @@bind-Value="model.IsActive" /&gt;
&lt;DxDateEdit @@bind-Value="model.StartDate" /&gt;
&lt;DxComboBox @@bind-Value="model.CategoryId" Data="categories" TextFieldName="Name" ValueFieldName="Id" /&gt;</code></pre>

        <h3>Event Handling</h3>
        <pre><code>&lt;DxButton Text="Save" Click="HandleClick" /&gt;
&lt;DxButton Text="Delete" Click="@@(async () =&gt; await DeleteItem(id))" /&gt;

@@code {
    void HandleClick(MouseEventArgs e) { /* ... */ }
}</code></pre>

        <h3>Dark Mode Toggle</h3>
        <pre><code>&lt;html data-dx-theme="dark"&gt;
    &lt;!-- All DExpressClone components automatically use dark theme --&gt;
&lt;/html&gt;</code></pre>

        <h3>Form Validation</h3>
        <pre><code>&lt;DxFormValidation Model="model" OnValidSubmit="HandleSubmit"&gt;
    &lt;DxFormItem FieldName="Name" LabelText="Full Name" Required MinLength="2"&gt;
        &lt;DxTextBox @@bind-Value="model.Name" /&gt;
    &lt;/DxFormItem&gt;
    &lt;DxFormItem FieldName="Email" LabelText="Email" Required Email&gt;
        &lt;DxTextBox @@bind-Value="model.Email" /&gt;
    &lt;/DxFormItem&gt;
&lt;/DxFormValidation&gt;

@@code {
    MyModel model = new();
    void HandleSubmit(EditContext context) { /* save */ }
}</code></pre>

        <h3>Toast Notifications</h3>
        <pre><code>@@inject DxToastService Toast

@@code {
    void Save() {
        try {
            // ... save logic ...
            Toast.ShowSuccess("Saved successfully!");
        } catch (Exception ex) {
            Toast.ShowError($"Error: {ex.Message}");
        }
    }
}</code></pre>

        <h3>File Upload</h3>
        <pre><code>&lt;DxFileUpload Accept=".jpg,.png,.pdf" MaxFileSize="5242880" Upload="HandleUpload" /&gt;

@@code {
    async Task HandleUpload(DxFileUploadEventArgs args) {
        using var ms = new MemoryStream();
        await args.FileStream.CopyToAsync(ms, args.CancellationToken);
        args.Progress.Report(100);
        // Save ms.ToArray()...
    }
}</code></pre>

        <h3>Grid with Selection and Paging</h3>
        <pre><code>&lt;DxGrid Data="items" PageSize="20" AllowSort="true" AllowFilter="true"
        @@bind-SelectedItem="selectedItem"&gt;
    &lt;DxGridDataColumn FieldName="Id" Caption="#" Width="60px" /&gt;
    &lt;DxGridDataColumn FieldName="Name" Caption="Name" /&gt;
    &lt;DxGridDataColumn FieldName="CreatedDate" Caption="Created" Format="d" /&gt;
&lt;/DxGrid&gt;</code></pre>

        <h3>Modal Dialog with Form</h3>
        <pre><code>&lt;DxModal @@bind-Visible="_showModal" HeaderText="Edit Record" Size="ModalSize.Large"&gt;
    &lt;BodyContent&gt;
        &lt;DxFormValidation Model="editModel" OnValidSubmit="HandleSave" ShowSubmitButton="false"&gt;
            &lt;DxFormItem FieldName="Name" LabelText="Name" Required&gt;
                &lt;DxTextBox @@bind-Value="editModel.Name" /&gt;
            &lt;/DxFormItem&gt;
        &lt;/DxFormValidation&gt;
    &lt;/BodyContent&gt;
    &lt;FooterTemplate&gt;
        &lt;DxButton Text="Cancel" RenderStyle="ButtonRenderStyle.Secondary" Click="() =&gt; _showModal = false" /&gt;
        &lt;DxButton Text="Save" RenderStyle="ButtonRenderStyle.Primary" ButtonType="ButtonType.Submit" /&gt;
    &lt;/FooterTemplate&gt;
&lt;/DxModal&gt;</code></pre>
    </section>
</div>
