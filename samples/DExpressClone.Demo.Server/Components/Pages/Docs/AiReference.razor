    <!-- 12. DxGrid -->
    <section class="doc-section">
        <h2>DxGrid&lt;TItem&gt;</h2>
        <p>Namespace: <code>DExpressClone.Components.Grid</code></p>

        <h3>DxGrid Parameters</h3>
        <table class="params-table">
            <thead><tr><th>Name</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
            <tbody>
                <tr><td><code>Data</code></td><td><code>IEnumerable&lt;TItem&gt;</code></td><td>—</td><td>The data source for the grid.</td></tr>
                <tr><td><code>PageSize</code></td><td><code>int</code></td><td><code>10</code></td><td>Number of rows per page.</td></tr>
