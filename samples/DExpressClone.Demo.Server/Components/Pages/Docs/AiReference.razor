            </tbody>
        </table>

        <h3>Methods</h3>
        <table class="params-table">
            <thead><tr><th>Method</th><th>Signature</th><th>Description</th></tr></thead>
            <tbody>
                <tr><td><code>BrowseAsync</code></td><td><code>Task BrowseAsync()</code></td><td>Open file browser dialog.</td></tr>
                <tr><td><code>RemoveFileAsync</code></td><td><code>Task RemoveFileAsync(DxFileUploadFile)</code></td><td>Remove a file from selection.</td></tr>
                <tr><td><code>UploadAllAsync</code></td><td><code>Task UploadAllAsync()</code></td><td>Upload all pending files.</td></tr>
            </tbody>
        </table>

        <h3>Related Types</h3>
        <p><code>DxFileUploadFile</code>: Name, Size, ContentType, Status (Pending/Uploading/Success/Error), ProgressPercent, ErrorMessage, PreviewDataUrl.</p>
        <p><code>DxFileUploadEventArgs</code>: File, FileStream, Progress (IProgress&lt;int&gt;), CancellationToken.</p>
        <p><code>FileUploadStatus</code>: Pending, Uploading, Success, Error.</p>

        <h3>Example</h3>
        <pre><code>&lt;DxFileUpload Accept=".jpg,.png,.pdf"
              MaxFileSize="5242880"
              MaxFileCount="5"
              Upload="HandleUpload" /&gt;

@@code {
    async Task HandleUpload(DxFileUploadEventArgs args) {
        for (int i = 0; i &lt;= 100; i += 10) {
            await Task.Delay(100);
            args.Progress.Report(i);
        }
    }
