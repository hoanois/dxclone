            <tbody>
                <tr><td><code>EditCellTemplate</code></td><td><code>RenderFragment&lt;object&gt;?</code></td><td>Custom cell template for edit mode. Context is the data item being edited.</td></tr>
            </tbody>
        </table>

        <h3>DxGridCommandColumn</h3>
        <table class="params-table">
            <thead><tr><th>Name</th><th>Type</th><th>Description</th></tr></thead>
            <tbody>
                <tr><td><code>HeaderText</code></td><td><code>string?</code></td><td>Column header text.</td></tr>
                <tr><td><code>CellTemplate</code></td><td><code>RenderFragment&lt;object&gt;?</code></td><td>Custom cell template for command buttons. Context is the data item.</td></tr>
                <tr><td><code>Width</code></td><td><code>string?</code></td><td>Column width.</td></tr>
            </tbody>
        </table>

        <h3>Examples</h3>
        <pre><code>&lt;DxGrid Data="employees" PageSize="10"&gt;
    &lt;DxGridDataColumn FieldName="FirstName" Caption="First Name" /&gt;
    &lt;DxGridDataColumn FieldName="LastName" Caption="Last Name" /&gt;
    &lt;DxGridDataColumn FieldName="Salary" Format="C2" Width="120px" /&gt;
&lt;/DxGrid&gt;</code></pre>

        <h4>Server-Side Data Loading</h4>
        <pre><code>&lt;DxGrid TItem="Employee" CustomData="@@LoadData" PageSize="20"&gt;
    &lt;DxGridDataColumn FieldName="FirstName" /&gt;
    &lt;DxGridDataColumn FieldName="Salary" DisplayFormat="{0:C0}" /&gt;
&lt;/DxGrid&gt;

@@code {
    async Task&lt;GridDataLoadResult&lt;Employee&gt;&gt; LoadData(GridDataLoadOptions options, CancellationToken ct)
    {
        var result = await MyService.GetPagedAsync(options.Skip, options.Take, ct);
        return new GridDataLoadResult&lt;Employee&gt; { Items = result.Items, TotalCount = result.Total };
    }
}</code></pre>

        <h4>Inline Editing</h4>
        <pre><code>&lt;DxGrid @@ref="_grid" TItem="Employee" Data="employees" KeyFieldName="Id"&gt;
    &lt;Columns&gt;
        &lt;DxGridDataColumn FieldName="FirstName"&gt;
            &lt;EditCellTemplate Context="item"&gt;
                @@{ var emp = (Employee)item; }
                &lt;DxTextBox @@bind-Text="emp.FirstName" /&gt;
            &lt;/EditCellTemplate&gt;
        &lt;/DxGridDataColumn&gt;
        &lt;DxGridCommandColumn HeaderText="Actions" Width="150px"&gt;
            &lt;CellTemplate Context="item"&gt;
                @@{ var emp = (Employee)item; }
                @@if (_grid?.IsEditing(emp) == true) {
                    &lt;button @@onclick="() =&gt; _grid.SaveEditAsync()"&gt;Save&lt;/button&gt;
                    &lt;button @@onclick="() =&gt; _grid.CancelEditAsync()"&gt;Cancel&lt;/button&gt;
                } else {
                    &lt;button @@onclick="() =&gt; _grid.StartEditAsync(emp)"&gt;Edit&lt;/button&gt;
                }
            &lt;/CellTemplate&gt;
        &lt;/DxGridCommandColumn&gt;
    &lt;/Columns&gt;
&lt;/DxGrid&gt;</code></pre>
    </section>

