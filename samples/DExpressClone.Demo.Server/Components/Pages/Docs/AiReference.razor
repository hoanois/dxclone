        <table class="params-table">
            <thead><tr><th>Name</th><th>Type</th><th>Description</th></tr></thead>
            <tbody>
                <tr><td><code>Upload</code></td><td><code>Func&lt;DxFileUploadEventArgs, Task&gt;?</code></td><td>Upload handler. Use args.Progress.Report(percent) for progress.</td></tr>
                <tr><td><code>FileAdded</code></td><td><code>EventCallback&lt;DxFileUploadFile&gt;</code></td><td>Fires when a file is added.</td></tr>
