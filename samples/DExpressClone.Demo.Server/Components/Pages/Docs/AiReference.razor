@page "/docs/ai-reference"
@rendermode InteractiveServer

<div class="doc-page">
    <h1>DExpressClone — AI Agent Reference</h1>
    <p class="doc-description">Complete API reference for all DExpressClone components. Optimized for AI agents building UI.</p>

    <!-- ===== SECTION 1: SETUP ===== -->
    <section class="doc-section">
        <h2>Setup</h2>

        <h3>CSS Reference (single import)</h3>
        <pre><code>&lt;link href="_content/DExpressClone.Components/css/dx-all.min.css" rel="stylesheet" /&gt;</code></pre>

        <h3>Service Registration</h3>
        <pre><code>builder.Services.AddDxComponents();</code></pre>

        <h3>Imports</h3>
        <pre><code>@@using DExpressClone.Components.Layout
@@using DExpressClone.Components.Editors.DxTextBox
@@using DExpressClone.Components.Editors.DxCheckBox
@@using DExpressClone.Components.Editors.DxNumericEdit
@@using DExpressClone.Components.Editors.DxRadioGroup
@@using DExpressClone.Components.Editors.DxDateEdit
@@using DExpressClone.Components.Editors.DxComboBox
@@using DExpressClone.Components.Editors.DxFormValidation
@@using DExpressClone.Components.Grid
@@using DExpressClone.Components.Charts
@@using DExpressClone.Components.Editors.DxFileUpload
@@using DExpressClone.Components.Editors</code></pre>
    </section>

    <!-- ===== SECTION 2: BASE CLASSES ===== -->
    <section class="doc-section">
        <h2>Base Classes</h2>

        <h3>DxComponentBase</h3>
        <table class="params-table">
            <thead><tr><th>Name</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
            <tbody>
                <tr><td><code>CssClass</code></td><td><code>string?</code></td><td><code>null</code></td><td>Additional CSS classes applied to the root element.</td></tr>
                <tr><td><code>Visible</code></td><td><code>bool</code></td><td><code>true</code></td><td>Whether the component is visible.</td></tr>
            </tbody>
        </table>

        <h3>DxInteractiveComponentBase (extends DxComponentBase)</h3>
        <table class="params-table">
            <thead><tr><th>Name</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
            <tbody>
                <tr><td><code>Enabled</code></td><td><code>bool</code></td><td><code>true</code></td><td>Whether the component is enabled for user interaction.</td></tr>
            </tbody>
        </table>

        <h3>DxFormEditorBase&lt;T&gt; (extends DxInteractiveComponentBase)</h3>
        <table class="params-table">
            <thead><tr><th>Name</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
            <tbody>
                <tr><td><code>Value</code></td><td><code>T</code></td><td>—</td><td>The editor's current value. Use @@bind-Value for two-way binding.</td></tr>
                <tr><td><code>ValueChanged</code></td><td><code>EventCallback&lt;T&gt;</code></td><td>—</td><td>Fires when the value changes.</td></tr>
                <tr><td><code>ReadOnly</code></td><td><code>bool</code></td><td><code>false</code></td><td>Whether the editor is read-only.</td></tr>
                <tr><td><code>NullText</code></td><td><code>string?</code></td><td><code>null</code></td><td>Placeholder text shown when the value is null/empty.</td></tr>
                <tr><td><code>ClearButtonDisplayMode</code></td><td><code>ClearButtonDisplayMode</code></td><td><code>Auto</code></td><td>When to show the clear button: Auto, Never, Always.</td></tr>
            </tbody>
        </table>
        <p>All form editors integrate with <code>EditContext</code> for validation support.</p>
    </section>

    <!-- ===== SECTION 3: ALL COMPONENTS ===== -->

    <!-- 1. DxButton -->
    <section class="doc-section">
        <h2>DxButton</h2>
        <p>Namespace: <code>DExpressClone.Components.Layout</code></p>

        <h3>Parameters</h3>
        <table class="params-table">
            <thead><tr><th>Name</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
            <tbody>
                <tr><td><code>Text</code></td><td><code>string?</code></td><td><code>null</code></td><td>The button's display text.</td></tr>
                <tr><td><code>IconCssClass</code></td><td><code>string?</code></td><td><code>null</code></td><td>CSS class for the button icon.</td></tr>
                <tr><td><code>RenderStyle</code></td><td><code>ButtonRenderStyle</code></td><td><code>Primary</code></td><td>Primary, Secondary, Success, Danger, Warning, Info, Light, Dark.</td></tr>
                <tr><td><code>RenderStyleMode</code></td><td><code>ButtonRenderStyleMode</code></td><td><code>Contained</code></td><td>Contained, Outlined, Text.</td></tr>
                <tr><td><code>NavigateUrl</code></td><td><code>string?</code></td><td><code>null</code></td><td>URL to navigate to when clicked.</td></tr>
                <tr><td><code>ButtonType</code></td><td><code>ButtonType</code></td><td><code>Button</code></td><td>Button, Submit, Reset.</td></tr>
                <tr><td><code>Enabled</code></td><td><code>bool</code></td><td><code>true</code></td><td>Whether the button is enabled.</td></tr>
                <tr><td><code>CssClass</code></td><td><code>string?</code></td><td><code>null</code></td><td>Additional CSS classes.</td></tr>
            </tbody>
        </table>

        <h3>Events</h3>
        <table class="params-table">
            <thead><tr><th>Name</th><th>Type</th><th>Description</th></tr></thead>
            <tbody>
                <tr><td><code>Click</code></td><td><code>EventCallback&lt;MouseEventArgs&gt;</code></td><td>Fires when the button is clicked.</td></tr>
            </tbody>
        </table>

        <h3>Example</h3>
        <pre><code>&lt;DxButton Text="Save" RenderStyle="ButtonRenderStyle.Primary" Click="HandleClick" /&gt;</code></pre>
    </section>

