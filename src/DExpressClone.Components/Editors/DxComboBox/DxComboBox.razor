@namespace DExpressClone.Components.Editors.DxComboBox
@typeparam TData
@typeparam TValue
@inherits DExpressClone.Components.Core.DxFormEditorBase<TValue>

<div class="@RootCssClass"
     id="@Id"
     @onmouseenter="HandleMouseEnter"
     @onmouseleave="HandleMouseLeave"
     @attributes="AdditionalAttributes">

    @if (!string.IsNullOrEmpty(LabelText))
    {
        <label class="dx-combobox-label">@LabelText</label>
    }

    <div class="dx-combobox-container" @ref="_containerRef">
        <input class="dx-combobox-input"
               type="text"
               value="@DisplayText"
               placeholder="@NullText"
               readonly="@(IsInputReadOnly)"
               disabled="@(!Enabled)"
               tabindex="@(TabIndex ?? 0)"
               @oninput="HandleInputChange"
               @onfocus="HandleFocusAsync"
               @onblur="HandleBlurAsync"
               @onclick="OpenDropdown"
               @onkeydown="HandleKeyDownAsync" />

        @if (ShowClearButton)
        {
            <button class="dx-combobox-clear-btn"
                    type="button"
                    tabindex="-1"
                    @onclick="HandleClearAsync"
                    aria-label="Clear">
                <svg viewBox="0 0 16 16" fill="none" width="14" height="14">
                    <path d="M4 4L12 12M12 4L4 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
            </button>
        }

        <button class="dx-combobox-button"
                type="button"
                tabindex="-1"
                disabled="@(!Enabled || ReadOnly)"
                @onclick="ToggleDropdown"
                aria-label="Toggle dropdown">
            <svg viewBox="0 0 16 16" fill="none" width="14" height="14">
                <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>
    </div>

    @if (IsDropdownOpen)
    {
        <div class="dx-dropdown-overlay" @onclick="CloseDropdown"></div>
        <DExpressClone.Components.Editors.DxComboBox.Internal.ComboBoxDropdown TData="TData" TValue="TValue"
            Items="GetFilteredItems()"
            ItemTemplate="ItemTemplate"
            GetItemText="GetItemText"
            GetItemCssClass="GetItemCssClass"
            OnItemSelected="SelectItemAsync"
            DropDownWidthMode="DropDownWidthMode"
            CssClass="@(_dropUp ? "dx-combobox-dropdown--dropup" : "")" />
    }

    @if (!IsValid && ShowBuiltInValidation)
    {
        <div class="dx-editor-validation-message">@ValidationMessage</div>
    }
</div>
