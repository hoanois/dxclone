@namespace DExpressClone.Components.Editors.DxTextBox
@inherits DExpressClone.Components.Core.DxFormEditorBase<string>

<div class="@RootCssClass"
     id="@Id"
     @onmouseenter="HandleMouseEnter"
     @onmouseleave="HandleMouseLeave"
     @attributes="AdditionalAttributes">

    @if (!string.IsNullOrEmpty(LabelText))
    {
        <label class="dx-textbox-label">@LabelText</label>
    }

    <div class="dx-textbox-container">
        <input class="dx-textbox-input"
               type="@InputType"
               value="@Text"
               placeholder="@NullText"
               maxlength="@MaxLength"
               disabled="@(!Enabled)"
               readonly="@ReadOnly"
               tabindex="@(TabIndex ?? 0)"
               @oninput="HandleInputAsync"
               @onchange="HandleChangeAsync"
               @onfocus="HandleFocusAsync"
               @onblur="HandleBlurAsync" />

        @if (ShowClearButton)
        {
            <button class="dx-textbox-clear-btn"
                    type="button"
                    tabindex="-1"
                    @onclick="HandleClearAsync"
                    aria-label="Clear">
                <svg viewBox="0 0 16 16" fill="none" width="14" height="14">
                    <path d="M4 4L12 12M12 4L4 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
            </button>
        }
    </div>

    @if (!IsValid && ShowBuiltInValidation)
    {
        <div class="dx-editor-validation-message">@ValidationMessage</div>
    }
</div>
