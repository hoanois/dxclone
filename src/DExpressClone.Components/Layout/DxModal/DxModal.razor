@namespace DExpressClone.Components.Layout
@inherits DExpressClone.Components.Core.DxComponentBase

@if (Visible)
{
    <div class="dx-modal-backdrop" @onclick="HandleBackdropClick" @onkeydown="HandleKeyDown">
        <div class="@DialogCssClass" @ref="_dialogRef" @onclick:stopPropagation="true"
             tabindex="-1" role="dialog" aria-modal="true" aria-label="@HeaderText">
            <div class="dx-modal-header">
                @if (HeaderTemplate is not null)
                {
                    @HeaderTemplate
                }
                else if (!string.IsNullOrEmpty(HeaderText))
                {
                    <h3 class="dx-modal-title">@HeaderText</h3>
                }
                @if (ShowCloseButton)
                {
                    <button class="dx-modal-close-btn" @onclick="CloseAsync" aria-label="Close">&times;</button>
                }
            </div>
            <div class="dx-modal-body">
                @BodyContent
            </div>
            @if (FooterTemplate is not null)
            {
                <div class="dx-modal-footer">
                    @FooterTemplate
                </div>
            }
        </div>
    </div>
}
