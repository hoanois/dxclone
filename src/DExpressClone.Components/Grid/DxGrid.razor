@namespace DExpressClone.Components.Grid
@typeparam TItem
@inherits DExpressClone.Components.Core.DxDataBoundComponentBase<TItem>
@using DExpressClone.Components.Grid.Internal
@using DExpressClone.Components.Grid.Models
@using DExpressClone.Components.Grid.DataProcessing

<CascadingValue Value="(IDxGridColumnOwner)this" IsFixed="true">
    @Columns
</CascadingValue>

<div class="@GridCssClass" id="@Id" style="@GridStyle" @attributes="AdditionalAttributes">
    @if (IsDataLoading)
    {
        @if (LoadingTemplate is not null)
        {
            <div class="dx-grid-loading-overlay">
                @LoadingTemplate
            </div>
        }
        else
        {
            <div class="dx-grid-loading-overlay">
                <span>Loading...</span>
            </div>
        }
    }
    else if ((IsServerMode ? _serverTotalCount : ProcessedData.Count) == 0 && !IsDataLoading)
    {
        @if (EmptyDataTemplate is not null)
        {
            @EmptyDataTemplate
        }
        else
        {
            <div class="dx-grid-empty">No data to display.</div>
        }
    }
    else
    {
        <div class="dx-grid-scroll-container">
            <GridHeader TItem="TItem"
                        Columns="@_columns"
                        SortDescriptors="@_sortDescriptors"
                        OnSortChanged="@HandleSortChanged"
                        AllowSort="@AllowSort" />

            @if (ShowFilterRow)
            {
                <GridFilterRow Columns="@_columns"
                               FilterDescriptors="@_filterDescriptors"
                               OnFilterChanged="@HandleFilterChanged" />
            }

            @if (IsVirtualizationMode)
            {
                <VirtualGridViewport TItem="TItem"
                                     Items="@ProcessedData"
                                     Columns="@_columns"
                                     RowHeight="@RowHeight"
                                     Height="@GridHeight"
                                     VirtualizationWindow="@_virtualizationState.CurrentWindow"
                                     TotalItemCount="@(IsServerMode ? _serverTotalCount : (int?)null)"
                                     ItemOffset="@(IsServerMode ? _serverWindowOffset : 0)"
                                     OnScroll="@HandleScroll"
                                     OnRowClick="@HandleRowClick"
                                     OnRowDoubleClick="@HandleRowDoubleClick"
                                     OnSelectionToggled="@HandleSelectionToggled"
                                     IsItemSelected="@_selectionModel.IsSelected"
                                     IsItemFocused="@IsItemFocused"
                                     IsItemEditing="@IsEditing"
                                     GetEditItem="@(item => _editState.IsEditing && IsEditing(item) ? (object)_editState.EditingItemCopy! : null)"
                                     GetEditContext="@(item => IsEditing(item) ? _editState.EditContext : null)" />
            }
            else
            {
                <div class="dx-grid-body" style="max-height:@GridHeight;">
                    @foreach (var item in PagedData)
                    {
                        <GridRow TItem="TItem"
                                 Item="@item"
                                 Columns="@_columns"
                                 IsSelected="@_selectionModel.IsSelected(item)"
                                 IsFocused="@IsItemFocused(item)"
                                 RowIndex="@(((IList<TItem>)ProcessedData).IndexOf(item))"
                                 RowHeight="@RowHeight"
                                 IsEditing="@IsEditing(item)"
                                 EditItem="@(_editState.IsEditing && IsEditing(item) ? (object)_editState.EditingItemCopy! : null)"
                                 RowEditContext="@(IsEditing(item) ? _editState.EditContext : null)"
                                 RowClick="@HandleRowClick"
                                 RowDoubleClick="@HandleRowDoubleClick"
                                 SelectionToggled="@HandleSelectionToggled" />
                    }
                </div>
            }
        </div>

        @if (PageSize > 0)
        {
            <GridPager PageIndex="@_pageIndex"
                       PageCount="@PageCount"
                       PageSize="@PageSize"
                       PageIndexChanged="@HandlePageIndexChanged" />
        }
    }
</div>
